{% schema %}
{
  "name": "Quality Products Slider",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Quality Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Slide Image"
        },
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name",
          "default": "Client Name"
        },
        {
          "type": "text",
          "id": "client_location",
          "label": "Client Location",
          "default": "Dubai, United Arab Emirates"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Quality Products Slider"
    }
  ]
}
{% endschema %}

<section class="quality-slider-section">
  <div class="page-width">
    
    <!-- Text Section -->
    <div class="text-section" id="text-section-{{ section.id }}">
      <h2 id="title-{{ section.id }}" class="section-title">
        {{ section.settings.heading }}
      </h2>

      <p id="desc-{{ section.id }}" class="section-desc">
        {{ section.settings.description }}
      </p>
    </div>

    <!-- Slider -->
    <div class="slider-container" id="slider-{{ section.id }}">

      {% for block in section.blocks %}
        <div class="card" {{ block.shopify_attributes }}>
          
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 1000
              | image_tag:
                loading: 'lazy',
                alt: block.settings.client_name
            }}
          {% endif %}

          <div class="drag-circle">Drag</div>

        </div>
      {% endfor %}

    </div>

    <!-- Bottom Info -->
    <div class="info-section">
      <h3 id="client-name-{{ section.id }}">
        {% if section.blocks.size > 0 %}
          {{ section.blocks.first.settings.client_name }}
        {% endif %}
      </h3>

      <p id="client-loc-{{ section.id }}">
        {% if section.blocks.size > 0 %}
          {{ section.blocks.first.settings.client_location }}
        {% endif %}
      </p>
    </div>

  </div>
</section>

<style>
  .quality-slider-section {
    background: #f8f9fa;
    padding: 100px 0;
    overflow: hidden;
  }

  .quality-slider-section .page-width {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .text-section {
    text-align: center;
    max-width: 700px;
    margin: 0 auto;
  }

  .section-title {
    font-size: 48px;
    font-weight: 400;
    color: #111;
    margin-bottom: 20px;
  }

  .section-desc {
    color: #666;
    line-height: 1.7;
    font-size: 16px;
    font-size: 21px;
    letter-spacing: 0;
    font-family: 'WorkSans';
  }

  .slider-container {
    position: relative;
    width: 100%;
    height: 520px;
    display: flex;
    justify-content: center;
    align-items: center;
    margin-top: 50px;
    touch-action: pan-y;
  }

  .card {
    position: absolute;
    width: 320px;
    height: 480px;
    overflow: hidden;
    border-radius: 6px;
    background: #fff;
    cursor: grab;
    will-change: transform;
    transition:
      transform 0.6s cubic-bezier(0.25, 1, 0.5, 1),
      opacity 0.6s ease;
  }

  .card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
    pointer-events: none;
  }

  .drag-circle {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 70px;
    height: 70px;
    border-radius: 50%;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(-50%, -50%) scale(0);
    transition: 0.3s ease;
    font-size: 14px;
    font-weight: 500;
    pointer-events: none;
  }

  .info-section {
    text-align: center;
    margin-top: 50px;
  }

  .info-section h3 {
    font-size: 24px;
    margin-bottom: 5px;
    color: #111;
  }

  .info-section p {
    color: #777;
  }

  @media screen and (max-width: 767px) {
    .quality-slider-section {
      padding: 70px 0;
    }

    .section-title {
      font-size: 34px;
    }

    .slider-container {
      height: 400px;
    }

    .card {
      width: 240px;
      height: 340px;
    }
  }
</style>

<script>
  (() => {

    const sectionId = "{{ section.id }}";

    const slider = document.getElementById(`slider-${sectionId}`);
    const cards = slider.querySelectorAll('.card');

    const slidesData = [
      {% for block in section.blocks %}
        {
          name: `{{ block.settings.client_name }}`,
          loc: `{{ block.settings.client_location }}`
        }{% unless forloop.last %},{% endunless %}
      {% endfor %}
    ];

    // START FROM CENTER
    let currentIndex = 1;

    const getKf = () => {

      const isMobile = window.innerWidth < 768;

      return {

        '-3': {
          x: isMobile ? -260 : -380,
          r: -25,
          s: 0.7,
          o: 0
        },

        '-2': {
          x: isMobile ? -200 : -280,
          r: -18,
          s: 0.82,
          o: 0
        },

        // LEFT SLIDE
        '-1': {
          x: isMobile ? -115 : -150,
          r: -10,
          s: 0.92,
          o: 1
        },

        // CENTER SLIDE
        '0': {
          x: 0,
          r: 0,
          s: 1,
          o: 1
        },

        // RIGHT SLIDE
        '1': {
          x: isMobile ? 115 : 150,
          r: 10,
          s: 0.92,
          o: 1
        },

        '2': {
          x: isMobile ? 200 : 280,
          r: 18,
          s: 0.82,
          o: 0
        },

        '3': {
          x: isMobile ? 260 : 380,
          r: 25,
          s: 0.7,
          o: 0
        }
      };
    };

    function lerp(start, end, t) {
      return start + (end - start) * t;
    }

    function getStyle(pos) {

      const kf = getKf();

      if (pos <= -3) return kf['-3'];
      if (pos >= 3) return kf['3'];

      let lower = Math.floor(pos);
      let upper = Math.ceil(pos);

      if (lower === upper) return kf[lower];

      let t = pos - lower;

      let k1 = kf[lower];
      let k2 = kf[upper];

      return {
        x: lerp(k1.x, k2.x, t),
        r: lerp(k1.r, k2.r, t),
        s: lerp(k1.s, k2.s, t),
        o: lerp(k1.o, k2.o, t)
      };
    }

    function updateCards() {

      cards.forEach((card, i) => {

        // INFINITE RELATIVE POSITION
        let rel = i - currentIndex;

        // HANDLE LOOP POSITIONS
        if (rel > cards.length / 2) {
          rel -= cards.length;
        }

        if (rel < -cards.length / 2) {
          rel += cards.length;
        }

        let style = getStyle(rel);

        card.style.transform =
          `translateX(${style.x}%) rotate(${style.r}deg) scale(${style.s})`;

        card.style.opacity = style.o;

        card.style.zIndex = 10 - Math.abs(rel);

        const circle = card.querySelector('.drag-circle');

        if (rel === 0) {

          card.onmouseenter = () => {
            circle.style.transform =
              'translate(-50%, -50%) scale(1)';
          };

          card.onmouseleave = () => {
            circle.style.transform =
              'translate(-50%, -50%) scale(0)';
          };

        } else {

          circle.style.transform =
            'translate(-50%, -50%) scale(0)';
        }
      });

      const safeIndex =
        ((currentIndex % cards.length) + cards.length) % cards.length;

      const nameEl =
        document.getElementById(`client-name-${sectionId}`);

      const locEl =
        document.getElementById(`client-loc-${sectionId}`);

      nameEl.innerText = slidesData[safeIndex].name;
      locEl.innerText = slidesData[safeIndex].loc;
    }

    // DRAG LOGIC

    let isDragging = false;
    let startX = 0;
    let currentX = 0;

    slider.addEventListener('mousedown', dragStart);
    slider.addEventListener('touchstart', dragStart, { passive: true });

    window.addEventListener('mousemove', dragMove);
    window.addEventListener('touchmove', dragMove, { passive: false });

    window.addEventListener('mouseup', dragEnd);
    window.addEventListener('touchend', dragEnd);

    function dragStart(e) {

      isDragging = true;

      startX =
        e.type.includes('mouse')
          ? e.pageX
          : e.touches[0].clientX;

      currentX = startX;
    }

    function dragMove(e) {

      if (!isDragging) return;

      const newX =
        e.type.includes('mouse')
          ? e.pageX
          : e.touches[0].clientX;

      const diff = newX - startX;

      currentX = newX;

      const threshold =
        window.innerWidth < 768 ? 200 : 350;

      let progress = diff / threshold;

      cards.forEach((card, i) => {

        let rel = i - currentIndex;

        // HANDLE LOOP POSITIONS
        if (rel > cards.length / 2) {
          rel -= cards.length;
        }

        if (rel < -cards.length / 2) {
          rel += cards.length;
        }

        let pos = rel + progress;

        let style = getStyle(pos);

        card.style.transition = 'none';

        card.style.transform =
          `translateX(${style.x}%) rotate(${style.r}deg) scale(${style.s})`;

        card.style.opacity = style.o;
      });
    }

    function dragEnd() {

      if (!isDragging) return;

      isDragging = false;

      let diff = currentX - startX;

      const threshold =
        window.innerWidth < 768 ? 50 : 100;

      // PREVIOUS
      if (diff > threshold) {
        currentIndex--;
      }

      // NEXT
      else if (diff < -threshold) {
        currentIndex++;
      }

      // INFINITE INDEX
      if (currentIndex < 0) {
        currentIndex = cards.length - 1;
      }

      if (currentIndex >= cards.length) {
        currentIndex = 0;
      }

      cards.forEach(card => {
        card.style.transition =
          'transform 0.6s cubic-bezier(0.25,1,0.5,1), opacity 0.6s ease';
      });

      updateCards();
    }

    updateCards();

    window.addEventListener('resize', () => {
      updateCards();
    });

  })();
</script>